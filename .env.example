# Storage backend: local | s3
RDF_STORAGE=local
RDF_LOCAL_STORAGE_PATH=/tmp/rdf/storage

# Queue backend: local | sqs
RDF_QUEUE=local
RDF_LOCAL_QUEUE_PATH=/tmp/rdf/queues

# Catalog backend: local | aws
RDF_CATALOG=local
RDF_LOCAL_CATALOG_PATH=/tmp/rdf/catalog

# Model backend: mock | real
RDF_MODELS=mock

# Robometer server (only used when RDF_MODELS=real)
RDF_ROBOMETER_SERVER_URL=http://localhost:8001
RDF_ROBOMETER_MODEL_PATH=robometer/Robometer-4B

# DemInf VAE checkpoints (only used when RDF_MODELS=real)
RDF_DEMINF_OBS_CKPT=/data/demonstration-information/checkpoints/obs_vae
RDF_DEMINF_ACTION_CKPT=/data/demonstration-information/checkpoints/action_vae

# S3 buckets (only used when RDF_STORAGE=s3)
RDF_S3_RAW_BUCKET=rdf-raw
RDF_S3_CLEAN_BUCKET=rdf-clean
RDF_S3_REGISTRY_BUCKET=rdf-registry

# SQS queues (only used when RDF_QUEUE=sqs)
RDF_SQS_EPISODE_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123/rdf-episodes
RDF_SQS_COHORT_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123/rdf-cohorts

# AWS region
AWS_DEFAULT_REGION=us-east-1
